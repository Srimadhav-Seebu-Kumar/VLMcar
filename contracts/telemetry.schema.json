{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vlmcar.local/contracts/telemetry.schema.json",
  "title": "TelemetryPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "device_id",
    "timestamp_ms",
    "uptime_ms",
    "free_heap_bytes",
    "wifi_rssi_dbm",
    "battery_mv",
    "frame_counter",
    "avg_loop_latency_ms",
    "mode"
  ],
  "properties": {
    "device_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "session_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "uptime_ms": {
      "type": "integer",
      "minimum": 0
    },
    "free_heap_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "wifi_rssi_dbm": {
      "type": "integer",
      "minimum": -120,
      "maximum": 0
    },
    "battery_mv": {
      "type": "integer",
      "minimum": 0
    },
    "frame_counter": {
      "type": "integer",
      "minimum": 0
    },
    "avg_loop_latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "last_heading_deg": {
      "type": ["integer", "null"],
      "minimum": -90,
      "maximum": 90
    },
    "last_throttle": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "last_error": {
      "type": ["string", "null"],
      "maxLength": 256
    },
    "mode": {
      "type": "string",
      "enum": ["AUTO", "MANUAL", "ESTOP", "IDLE"]
    }
  }
}
