{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vlmcar.local/prompts/json_schema_decision.json",
  "title": "ModelDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "confidence", "reason_code", "scene_summary", "hazards"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["FORWARD", "LEFT", "RIGHT", "STOP"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "scene_summary": {
      "type": "string",
      "maxLength": 200
    },
    "hazards": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 64
      }
    }
  }
}
