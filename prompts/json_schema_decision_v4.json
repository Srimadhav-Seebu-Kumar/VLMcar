{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DriverDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["left_zone", "center_zone", "right_zone", "action", "confidence"],
  "properties": {
    "left_zone": {
      "type": "string",
      "enum": ["CLEAR", "BLOCKED"]
    },
    "center_zone": {
      "type": "string",
      "enum": ["CLEAR", "BLOCKED"]
    },
    "right_zone": {
      "type": "string",
      "enum": ["CLEAR", "BLOCKED"]
    },
    "action": {
      "type": "string",
      "enum": ["FORWARD", "LEFT", "RIGHT", "STOP"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
